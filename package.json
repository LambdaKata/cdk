{
  "name": "@lambdakata/cdk",
  "version": "0.1.7",
  "description": "AWS CDK integration for Lambda Kata - Node.js Lambdas running via Lambda Kata runtime",
  "main": "out/dist/index.js",
  "types": "out/tsc/src/index.d.ts",
  "scripts": {
    "build": "rm -rf ./dist && rm -rf ./out && rm -rf ./lib && yarn run build:cdk && yarn run build:snapstart && yarn run types",
    "build:snapstart": "yarn run build:config && node dist/utils/build.js --target=snapstartHandler",
    "types": "tsc --emitDeclarationOnly && tsc-alias",
    "build:cdk": "yarn run build:config && node dist/utils/build.js --target=cdk",
    "build:minify": "yarn run build:config && node dist/utils/build.js",
    "build:config": "esbuild --bundle --platform=node utils/esbuild/esbuild.build.ts --outfile=dist/utils/build.js --external:esbuild",
    "watch": "tsc -w",
    "test": "npx jest --runInBand --colors --verbose --testTimeout=30000 --forceExit --detectOpenHandles",
    "test:watch": "npx jest --watch --testTimeout=30000 --runInBand",
    "lint": "eslint src/ test/ --ext .ts",
    "clean": "rm -rf lib coverage",
    "docs": "yarn run docs:md && yarn run docs:html",
    "docs:md": "typedoc --options ./docs/docs.config/typedoc.md.json",
    "docs:html": "typedoc --options ./docs/docs.config/typedoc.html.json",
    "npm:publish": "yarn run build && npm publish --access public"
  },
  "files": [
    "out/dist/**/*",
    "out/tsc/src/**/*.d.ts"
  ],
  "exports": {
    ".": {
      "types": "./out/tsc/src/index.d.ts",
      "default": "./out/dist/index.js"
    }
  },
  "keywords": [
    "aws",
    "cdk",
    "lambda",
    "lambdakata",
    "lambda-kata",
    "nodejs",
    "python",
    "serverless"
  ],
  "author": "Raman Marozau, raman@worktif.com",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/lambdakata/cdk.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "aws-cdk-lib": "^2.0.0",
    "constructs": "^10.0.0",
    "esbuild": "^0.23.0"
  },
  "dependencies": {
    "@aws-sdk/client-lambda": "^3.500.0",
    "@aws-sdk/client-s3": "^3.500.0",
    "@aws-sdk/client-sts": "^3.500.0",
    "dotenv": "^17.2.3",
    "@lambda-kata/licensing": "0.1.33",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@worktif/utils": "^0.2.34",
    "aws-cdk-lib": "^2.130.0",
    "constructs": "^10.3.0",
    "esbuild": "^0.27.2",
    "eslint": "^8.56.0",
    "fast-check": "^3.15.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.3.3"
  },
  "peerDependenciesMeta": {
    "esbuild": {
      "optional": true
    }
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
